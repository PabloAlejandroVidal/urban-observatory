# ==========================================
# App
# ==========================================

NODE_ENV=development
APP_NAME=Urban Observatory

# ==========================================
# Backend API
# ==========================================

API_PORT=3000
API_PREFIX=api

# JWT
JWT_SECRET=change_me_in_local_env
JWT_EXPIRES_IN=1d

# ==========================================
# Database
# ==========================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=urban_observatory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urban_observatory

# ==========================================
# Frontend
# ==========================================

WEB_PORT=4200
WEB_API_URL=http://localhost:3000/api

# ==========================================
# Deployment
# ==========================================

DOMAIN=localhost
PUBLIC_API_URL=http://localhost:3000/api
PUBLIC_WEB_URL=http://localhost:4200
